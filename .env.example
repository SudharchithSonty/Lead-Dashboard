# HubSpot Integration
HUBSPOT_ACCESS_TOKEN=your-hubspot-service-key-or-private-app-token
HUBSPOT_PORTAL_ID=your-portal-id-here

# Database (defaults to SQLite file in backend/)
DATABASE_URL=sqlite:///./leads.db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend connects to this URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Allowed CORS origin for the frontend
CORS_ORIGIN=http://localhost:3000

# Public URL of the deployed backend (used when hosting frontend on HubSpot)
BACKEND_PUBLIC_URL=http://localhost:8000

# Purge leads older than this many hours (startup, periodic, and on list/analytics)
LEAD_RETENTION_HOURS=24
# How often the background purge runs while the server is up (seconds)
LEAD_RETENTION_POLL_SECONDS=900
